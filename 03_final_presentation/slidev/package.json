{
  "name": "nephrovision-defense-slides",
  "version": "1.0.0",
  "description": "NephroVision Final Defense Presentation - Slidev",
  "scripts": {
    "dev": "slidev --open",
    "build": "slidev build",
    "export": "slidev export",
    "export:pptx": "slidev export --format pptx --output export/NephroVision_Defense.pptx",
    "export:pdf": "slidev export --format pdf --output export/NephroVision_Defense.pdf",
    "export:png": "slidev export --format png --output export/slides",
    "export:pptx:local": "npx slidev export --format pptx --output export/NephroVision_Defense.pptx",
    "install:chromium": "npx playwright install chromium"
  },
  "dependencies": {
    "@slidev/cli": "^0.49.0",
    "@slidev/theme-default": "^0.21.2",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "playwright-chromium": "^1.61.1"
  }
}
